Options -Indexes +FollowSymLinks
DirectoryIndex index.php
ErrorDocument 404 /404.php
ServerSignature Off

RewriteEngine On
RewriteBase /

# --- protect internal folders ---
RewriteRule ^(inc|data)/ - [F,L]

# --- block sensitive / source files ---
<FilesMatch "(config(\.local)?\.php|leads\.log)$">
  Require all denied
</FilesMatch>
<FilesMatch "(?i)\.(sql|log|md|ya?ml|ini|sh|bak|inc)$">
  Require all denied
</FilesMatch>
# block dotfiles (.git, .gitignore, .env, .htaccess, etc.)
<FilesMatch "^\.">
  Require all denied
</FilesMatch>

# --- force HTTPS ---
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --- add trailing slash to clean URLs (not files) ---
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !(\.[a-zA-Z0-9]+|/)$
RewriteRule ^(.*)$ /$1/ [L,R=301]

# --- routes ---
RewriteRule ^services/?$ services.php [L]
RewriteRule ^services/([a-z0-9-]+)/?$ service.php?s=$1 [L,QSA]
RewriteRule ^blog/?$ blog.php [L]
RewriteRule ^blog/([a-z0-9-]+)/?$ post.php?slug=$1 [L,QSA]
RewriteRule ^leads/?$ leads.php [L]
RewriteRule ^(about|contact|coverage|amc|privacy|terms|pdpa|cookie)/?$ $1.php [L]

# --- security headers ---
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header unset X-Powered-By
  Header always unset X-Powered-By
</IfModule>

# --- caching for static assets ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 6 months"
  ExpiresByType image/png "access plus 6 months"
  ExpiresByType image/webp "access plus 6 months"
  ExpiresByType image/svg+xml "access plus 6 months"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|jpg|jpeg|png|webp|svg)$">
    Header set Cache-Control "public, max-age=15552000"
  </FilesMatch>
</IfModule>
